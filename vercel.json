{
  "buildCommand": "",
  "outputDirectory": "public",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    }
  ],
  "functions": {
    "api/refresh.ts": {
      "maxDuration": 60,
      "memory": 256
    },
    "api/sync.ts": {
      "maxDuration": 120,
      "memory": 256
    },
    "api/sync-live.ts": {
      "maxDuration": 30,
      "memory": 256,
      "includeFiles": "data/**"
    },
    "api/data.ts": {
      "maxDuration": 15,
      "memory": 128,
      "includeFiles": "data/**"
    }
  },
  "crons": [
    {
      "path": "/api/sync-live",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/refresh",
      "schedule": "0 9 * * 0"
    }
  ]
}
