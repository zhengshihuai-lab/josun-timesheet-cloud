{
  "buildCommand": "",
  "outputDirectory": "public",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    }
  ],
  "functions": {
    "api/refresh.ts": {
      "maxDuration": 60,
      "memory": 256
    },
    "api/sync.ts": {
      "maxDuration": 120,
      "memory": 256
    },
    "api/data.ts": {
      "maxDuration": 10,
      "memory": 128,
      "includeFiles": "data/**"
    }
  },
  "crons": [
    {
      "path": "/api/refresh",
      "schedule": "0 9 * * 0"
    }
  ],
  "env": {
    "WECOM_DOC_ID": "",
    "WECOM_CORP_ID": "",
    "WECOM_API_SECRET": "",
    "WECOM_AGENT_ID": "",
    "WECOM_ACCESS_TOKEN": "",
    "YONSUITE_APP_KEY": "",
    "YONSUITE_APP_SECRET": "",
    "YONSUITE_TENANT_ID": "",
    "YONSUITE_DATA_CENTER": "c1.yonyoucloud.com",
    "SYNC_MODE": "dry-run",
    "SUPABASE_URL": "",
    "SUPABASE_ANON_KEY": "",
    "CACHE_FILE_PATH": "data/timesheet-cache.json"
  }
}
